PORT=3099
NODE_ENV=production
# Optional: override beacon URL
BEACON_API_URL=https://beacon.peakd.com/api/nodes
# Optional: minimum beacon score to accept a node (default: 80)
MIN_NODE_SCORE=80
# Optional: poll interval in milliseconds (default: 30000)
POLL_INTERVAL_MS=30000
# Optional: rolling window in milliseconds (default: 1800000 = 30 min)
WINDOW_MS=1800000
# Optional: cold-start batch size for block_api.get_block_range (default: 50)
BULK_BATCH_SIZE=50
# Optional: Hive account whose top-level replies count as "snaps" (default: peak.snaps)
SNAP_CONTAINER_AUTHOR=peak.snaps
# Optional: how long to retain snap event timestamps, in ms (default: 3600000 = 1h)
SNAP_RETENTION_MS=3600000
# Optional: how long to retain per-author snap counts for trending suggestions,
# in ms (default: 86400000 = 24h). Longer than SNAP_RETENTION_MS on purpose —
# this backs a "who to follow" pool that needs to stay populated even during
# quiet periods.
TRENDING_AUTHORS_WINDOW_MS=86400000
# Optional: account that receives patron support (default: snapie)
PATRON_ACCOUNT=snapie
# Optional: memo substring that marks a transfer as a patron subscription (default: snapiepatron)
PATRON_MEMO_TAG=snapiepatron
# Optional: how long a subscription stays valid without a renewal, in ms
# (default: 3024000000 = 35 days — acts as the grace period; no separate concept needed)
PATRON_SUBSCRIPTION_RETENTION_MS=3024000000
# Optional: how often to re-sync delegation data from Ecency, in ms (default: 3600000 = 1h)
DELEGATION_SYNC_INTERVAL_MS=3600000
# Optional: override the Ecency received-vesting API base URL
ECENCY_VESTING_URL=https://ecency.com/private-api/received-vesting
# Optional: override the CoinGecko simple-price URL used for the live HIVE/USD
# rate that delegation tiers are pegged to
COINGECKO_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=hive&vs_currencies=usd
